{
  "manifest_version": 3,
  "name": "CarLens",
  "version": "0.1.0",
  "description": "Evaluates used car listings with AI-powered insights.",
  "permissions": [],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.carfax.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CarLens"
  }
}
